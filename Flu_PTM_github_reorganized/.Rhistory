library(tidyverse)
library(ggplot2)
library(ggseqlogo)
library(here)
path_root <- "c:/Users/Ashley/Documents/flu_project_revisions/Flu_PTM_github"
setwd(path_root)
nex_file <- file.path(
normalizePath(file.path(here::here(), ".."), winslash = "/", mustWork = FALSE),
"cluster_output_final_converged",
"processed_segments_fixed_final",
"seg1",
"PB2_polymerase_multistate.txt"
)
original_alphabet <- c("A", "C", "K", "M", "N", "O", "Q", "R", "S", "T", "Y", "U", "H", "L", "X", "-", "?")
alphanumeric_alphabet <- c("A", "C", "K", "M", "N", "O", "Q", "R", "S", "T", "Y", "U", "H", "L", "X", "Z", "W")
symbol_mapping <- setNames(alphanumeric_alphabet, original_alphabet)
lines <- readLines(nex_file)
st <- which(stringr::str_detect(lines, stringr::regex("^\\s*MATRIX", ignore_case = TRUE)))[1] + 1
ends <- which(stringr::str_trim(lines) == ";")
en <- ends[ends > st][1] - 1
mat <- lines[st:en] |> stringr::str_trim()
mat <- mat[mat != ""]
sequences <- purrr::map_chr(mat, function(line) {
parts <- stringr::str_split(line, "\\s+")[[1]]
original_seq <- paste(parts[-1], collapse = "")
mapped_seq <- original_seq
for (i in seq_along(original_alphabet)) {
mapped_seq <- gsub(
paste0("\\", original_alphabet[i]),
symbol_mapping[original_alphabet[i]],
mapped_seq,
fixed = TRUE
)
}
mapped_seq
})
print(length(sequences))
print(head(nchar(sequences)))
p <- ggseqlogo(
sequences,
method = "probability",
namespace = alphanumeric_alphabet
)
print(p)
rm(list = ls())
graphics.off()
path <- "c:/Users/Ashley/Documents/flu_project_revisions/Flu_PTM_github/scripts/figures/fig3_ptm_seqlogo.R"
