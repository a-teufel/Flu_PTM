# ChimeraX script with floating labels and leader lines - ONLY uncomment the sections for PDBs you actually have
# Save as highlight_structures.cxc  

# Set up nice rendering
lighting soft
set bgColor white
graphics silhouettes true
set silhouetteWidth 2

# ===== UNCOMMENT ONLY THE PROTEINS YOU HAVE ===== 

# PB2 polymerase - UNCOMMENT IF YOU HAVE PB2 PDB
# open YOUR_PB2_FILENAME.pdb
# cartoon
# color lightgray
# select :33,514,741
# color sel red
# show sel atoms
# style sel sphere
# size sel atomRadius 1.5
# label sel residues text "{0.name}{0.number}"
# label sel color black
# label sel size 18
# label sel height 2.0
# label sel offset 1.5,1.5,0
# 2dlabels sel color black
# 2dlabels sel visibility true
# view orient
# save PB2_selection_sites_labeled.png width 2400 height 2000 supersample 3
# close

# PB1-F2 protein - UNCOMMENT IF YOU HAVE PB1-F2 PDB
# open YOUR_PB1F2_FILENAME.pdb
