# HA protein - UNCOMMENT IF YOU HAVE HA PDB
 open HA.pdb.pdb
 cartoon
 color lightgray
 # Positive selection sites (red)
 select :182,570
 color sel red
 show sel atoms
 style sel sphere
 size sel atomRadius 1.5
 label sel residues text "{0.name}{0.number}"
 label sel color black
 label sel size 18
 label sel height 2.0
 label sel offset 1.5,1.5,0
 2dlabels sel color black
 2dlabels sel visibility true
 # Purifying selection sites (blue)
 select :56,143,281,519
 color sel blue
 show sel atoms
 style sel sphere
 size sel atomRadius 1.5
 label sel residues text "{0.name}{0.number}"
 label sel color black
 label sel size 18
 label sel height 2.0
 label sel offset 1.5,1.5,0
 2dlabels sel color black
 2dlabels sel visibility true
 view orient
 save HA_selection_sites_labeled.png width 2400 height 2000 supersample 4
 close

